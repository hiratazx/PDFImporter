# frozen_string_literal: true

# This Gemfile tracks the vendored gems in pdf_importer/lib
# so Dependabot can monitor them for updates.
# These gems are NOT installed via Bundler at runtime — they are
# manually vendored into the extension for SketchUp compatibility.

source "https://rubygems.org"

gem "pdf-reader", "~> 2.0"
gem "ascii85",    "~> 2.0"
gem "hashery",    "~> 2.0"
gem "afm",        "~> 0.2"
gem "rc4",        "~> 0.1"
gem "ttfunk",     "~> 1.7"
